---
// 植物卡：磨砂玻璃浮在「活体土柱」背景之上，透出背景、暗区自适应（深色玻璃 + 浅字）。
// 明/暗由所在 .zone 注入的 --card-* 变量决定（见 index.astro），文字恒可读。
// 顶部全宽等高照片行 + 介绍区（正文主栏 | 数据档案副栏）。
// data-* 锚点供 descent.ts 联动（卡片揭示 / 纵轴标记）。
import { render, type CollectionEntry } from 'astro:content';
import PhotoFrame from './PhotoFrame.astro';
import { LIFEFORM_META } from '../lib/lifeform';

interface Props {
  plant: CollectionEntry<'plants'>;
}

const { plant } = Astro.props;
const d = plant.data;
const meta = LIFEFORM_META[d.lifeform];
const { Content } = await render(plant);

// 数据字段（标签 → 值）。
const fields: Array<[string, string]> = [
  ['株高', d.height],
  ['茎', d.stem],
  ['光照', d.light],
  ['土壤', d.soil],
  ['群落层次', d.layer],
  ['物候', d.phenology],
  ['分布', d.distribution],
  ['伴生', d.companions.join('、')],
];
---

<article
  class="card"
  id={plant.id}
  data-plant-id={plant.id}
  data-lifeform={d.lifeform}
  data-bud-pos={d.budPos}
  data-reveal
>
  <header class="card-head">
    <div class="title">
      <h3 class="name u-display">{d.name}</h3>
      <p class="u-latin latin">{d.latin}</p>
    </div>
    <p class="u-label family">{d.family} · {meta.zh}</p>
  </header>

  <div class="card-body">
    <div class="media">
      <PhotoFrame
        photos={d.photos}
        name={d.name}
        altHint={`${meta.zh}，${d.budHeight}`}
        tint={meta.tint}
      />

    </div>

    <div class="info">
      <dl class="data-grid">
        {
          fields.map(([k, v]) => (
            <div class="datum">
              <dt class="u-label">{k}</dt>
              <dd>{v}</dd>
            </div>
          ))
        }
      </dl>

      <div class="prose">
        <Content />
      </div>
    </div>
  </div>
</article>

<style>
  .card {
    /* 磨砂玻璃：透出背景、暗区自适应（变量来自所在 .zone） */
    color: var(--card-fg);
    padding: clamp(var(--s4), 3vw, var(--s6));
    background: var(--card-bg);
    backdrop-filter: blur(var(--glass-blur)) saturate(1.3);
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(1.3);
    border: 1px solid var(--card-bd);
    border-radius: var(--radius-lg);
    box-shadow: var(--glass-shadow), var(--card-hl);
    scroll-margin-top: var(--s5);
    transition:
      box-shadow var(--dur-2) var(--ease-out),
      transform var(--dur-2) var(--ease-out);
  }
  .card:hover {
    box-shadow:
      var(--glass-shadow),
      var(--card-hl),
      0 38px 72px -30px oklch(0.14 0.05 60 / 0.5);
    transform: translateY(-2px);
  }

  .card-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s2) var(--s4);
    padding-bottom: var(--s3);
    border-bottom: 1px solid var(--card-line);
    margin-bottom: var(--s5);
  }
  .title {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--s2) var(--s3);
  }
  .name {
    font-size: var(--fs-h2);
    font-weight: 600;
    letter-spacing: 0;
  }
  .latin {
    font-size: var(--fs-body);
    color: var(--card-fg-2);
  }
  .family {
    color: var(--card-fg-2);
  }

  /* 单列竖向：照片在上、介绍在下 */
  .card-body {
    display: grid;
    gap: clamp(var(--s5), 4vw, var(--s6));
  }

  /* 媒体（照片）在上，占满整卡宽 */
  .media {
    display: block;
  }

  /* 介绍（数据条在上、正文双栏在下）：纵向堆叠，两块都占满整宽 */
  .info {
    display: grid;
    gap: clamp(var(--s5), 4vw, var(--s6));
  }

  /* 数据条：整宽自适应横向网格（紧凑约 4 列），底部分隔线与正文分开 */
  .data-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--s4) var(--s5);
    margin: 0;
    padding-bottom: clamp(var(--s4), 3vw, var(--s5));
    border-bottom: 1px solid var(--card-line);
  }
  .datum dt {
    margin-bottom: 4px;
    color: var(--card-fg-2);
  }
  .datum dd {
    margin: 0;
    font-size: var(--fs-sm);
    line-height: 1.55;
  }

  /* 正文：数据条之下，桌面分两栏填满整宽、中缝细线；窄屏单栏 */
  .prose {
    line-height: var(--lh-body);
    font-size: clamp(1.125rem, 1.06rem + 0.4vw, 1.275rem);
  }
  @media (min-width: 768px) {
    .prose {
      columns: 2;
      column-gap: clamp(var(--s6), 5vw, var(--s7));
      column-rule: 1px solid var(--card-line);
      orphans: 3;
      widows: 3;
    }
  }
  .prose :global(p) {
    margin: 0 0 var(--s4);
  }
  .prose :global(p:last-child) {
    margin-bottom: 0;
  }
  .prose :global(strong) {
    color: var(--card-accent);
    font-weight: 600;
  }
</style>
