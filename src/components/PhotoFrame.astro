---
// 照片框：有实拍则用 astro:assets 自动优化（WebP/AVIF + srcset + 懒加载）；
// 未到位时回退到优雅占位框，标注 全株 / 中景 / 特写，不阻塞开发（P5 接入照片）。
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  photos: ImageMetadata[];
  name: string;
  altHint: string; // 如「高位芽，芽位 >25cm」
  tint: string; // 该生活型的占位色块色（来自 LIFEFORM_META.tint）
}

const { photos, name, altHint, tint } = Astro.props;
const kinds = ['全株', '中景', '特写'] as const;
---

<figure class="photos" aria-label={`${name} 实拍`}>
  {
    kinds.map((kind, i) =>
      photos[i] ? (
        <div class="frame has-photo">
          <Image
            src={photos[i]}
            alt={`${name} ${kind}（${altHint}）`}
            widths={[320, 640, 960]}
            sizes="(max-width: 820px) 90vw, 320px"
            loading="lazy"
            data-parallax
          />
          <figcaption class="u-label">{kind}</figcaption>
        </div>
      ) : (
        <div
          class="frame is-empty"
          style={`--tint:${tint}`}
          role="img"
          aria-label={`${name} ${kind}照片待补拍`}
        >
          <span class="empty-name" aria-hidden="true">
            {name}
          </span>
          <figcaption class="u-label">{kind}</figcaption>
        </div>
      )
    )
  }
</figure>

<style>
  /* 马赛克：1 张「全株」大图 + 2 个方形色块占位（中景 / 特写） */
  .photos {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s2);
    margin: 0;
  }
  .frame {
    position: relative;
    aspect-ratio: 1 / 1;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--card-border);
    background: var(--paper-2);
  }
  /* 第一张（全株）占满整行、更大 */
  .frame:first-child {
    grid-column: 1 / -1;
    aspect-ratio: 16 / 11;
  }
  .frame :global(img) {
    position: absolute;
    top: -15%;
    left: 0;
    width: 100%;
    height: 130%;
    object-fit: cover;
    transform-origin: center;
  }
  .frame figcaption {
    position: absolute;
    left: var(--s2);
    bottom: var(--s2);
    padding: 1px 6px;
    border-radius: var(--radius-sm);
    background: oklch(1 0 0 / 0.7);
    backdrop-filter: blur(2px);
  }
  /* 占位色块：按生活型分色（大地色，沿剖面深度），安静不喧宾夺主。
     细微对角高光让纯色不发死，但绝不抢眼。 */
  .is-empty {
    display: grid;
    place-items: center;
    background:
      linear-gradient(155deg, oklch(1 0 0 / 0.12), oklch(0 0 0 / 0.06)),
      var(--tint);
    border-color: oklch(0 0 0 / 0.08);
  }
  .is-empty .empty-name {
    font-family: var(--display);
    font-size: var(--fs-h3);
    font-weight: 540;
    color: oklch(1 0 0 / 0.92);
    text-shadow: 0 1px 2px oklch(0 0 0 / 0.25);
    letter-spacing: var(--tracking-cn);
  }
  .is-empty figcaption {
    background: oklch(0 0 0 / 0.22);
    color: oklch(1 0 0 / 0.92);
    backdrop-filter: blur(1px);
  }
</style>
