---
// 照片框：有实拍则用 astro:assets 自动优化（WebP/AVIF + srcset + 懒加载）。
// 排版＝「两端对齐画廊一行」(justified row)：三图等高、宽度按各自长宽比伸缩、
// 铺满整宽、不留缝、不裁切（Flickr 式解法）。原理：flex-basis:0 + flex-grow:比例
// → 宽度∝比例；aspect-ratio:比例 → 高度=宽度/比例=常数 → 三图等高。
// 框比例＝图比例，故 object-fit:cover 满幅而不裁。窄屏远景换行独占一行。
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  photos: ImageMetadata[];
  name: string;
  altHint: string; // 如「高位芽，芽位 >25cm」
  tint: string; // 该生活型的占位色块色（来自 LIFEFORM_META.tint）
}

const { photos, name, altHint, tint } = Astro.props;
const kinds = ['全株', '中景', '特写'] as const;
const fallbackAR = [1.3, 1, 1]; // 占位框（无图时）兜底比例
---

<figure class="photos" aria-label={`${name} 实拍`}>
  {
    kinds.map((kind, i) => {
      const ar = photos[i] ? photos[i].width / photos[i].height : fallbackAR[i];
      return photos[i] ? (
        <div
          class:list={['frame', 'has-photo', { 'frame--lead': i === 0 }]}
          style={`flex-grow:${ar.toFixed(4)};aspect-ratio:${photos[i].width} / ${photos[i].height}`}
        >
          <Image
            src={photos[i]}
            alt={`${name} ${kind}（${altHint}）`}
            widths={[320, 480, 720]}
            sizes="(max-width: 600px) 92vw, 32vw"
            loading="lazy"
          />
          <figcaption class="u-label">{kind}</figcaption>
        </div>
      ) : (
        <div
          class:list={['frame', 'is-empty', { 'frame--lead': i === 0 }]}
          style={`--tint:${tint};flex-grow:${ar};aspect-ratio:${ar}`}
          role="img"
          aria-label={`${name} ${kind}照片待补拍`}
        >
          <span class="empty-name" aria-hidden="true">{name}</span>
          <figcaption class="u-label">{kind}</figcaption>
        </div>
      );
    })
  }
</figure>

<style>
  /* 两端对齐画廊行：等高、按比例分宽、铺满、不裁切 */
  .photos {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s2);
    margin: 0;
  }
  .frame {
    position: relative;
    flex-basis: 0;
    flex-shrink: 1;
    min-width: 0;
    /* flex-grow 与 aspect-ratio 由内联按真实比例给出 */
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--card-border);
    background: var(--paper-2);
  }
  .frame :global(img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover; /* 框比例＝图比例，cover 即满幅不裁 */
  }
  .frame figcaption {
    position: absolute;
    left: var(--s2);
    bottom: var(--s2);
    padding: 1px 6px;
    border-radius: var(--radius-sm);
    background: oklch(1 0 0 / 0.7);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
  }
  .frame.has-photo {
    transition: box-shadow var(--dur-2) var(--ease-out);
  }
  .frame.has-photo:hover {
    box-shadow: inset 0 0 0 1px oklch(1 0 0 / 0.25);
  }

  /* 窄屏：远景换行独占整宽，中景/特写在下一行按比例等高并排 */
  @media (max-width: 600px) {
    .photos .frame--lead {
      flex-basis: 100%;
    }
  }

  /* 占位色块（无图时）：按生活型分色（大地色），安静不喧宾夺主 */
  .is-empty {
    display: grid;
    place-items: center;
    background:
      linear-gradient(155deg, oklch(1 0 0 / 0.12), oklch(0 0 0 / 0.06)),
      var(--tint);
    border-color: oklch(0 0 0 / 0.08);
  }
  .is-empty .empty-name {
    font-family: var(--display);
    font-size: var(--fs-h3);
    font-weight: 540;
    color: oklch(1 0 0 / 0.92);
    text-shadow: 0 1px 2px oklch(0 0 0 / 0.25);
    letter-spacing: var(--tracking-cn);
  }
  .is-empty figcaption {
    background: oklch(0 0 0 / 0.22);
    color: oklch(1 0 0 / 0.92);
    backdrop-filter: blur(1px);
  }
</style>
