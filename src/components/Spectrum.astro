---
// 「生活型谱」终章：把整段下潜收束成一组比例。
// 五种气候各一条 100% 堆叠条（段序＝冠层→种子＝绿→褐，与下潜剖面同序）。
// SSR 直接渲染静态条（无 JS 完整可用、可读、带 ARIA）；spectrum.ts 用 D3 增强
// （生长过渡 / 图例跨行高亮 + 趋势缎带 / tooltip）。is-ready 后切到 D3 视图。
import { SPECTRUM_ROWS, SPECTRUM_CLASSES, SPECTRUM_COLOR } from '../lib/spectrum';
import { LIFEFORM_ORDER, LIFEFORM_META } from '../lib/lifeform';

const fbLabel = (label: string, values: Record<string, number>) =>
  `${label}：` + LIFEFORM_ORDER.map((lf) => `${LIFEFORM_META[lf].zh} ${values[lf]}%`).join('、');
---

<section
  class="spectrum"
  id="spectrum"
  aria-labelledby="spectrum-title"
  data-spectrum-section
  data-depth="生活型谱 · 回看全谱"
>
  <div class="wrap">
    <header class="spec-head" data-reveal>
      <p class="u-label kicker">LIFE-FORM SPECTRUM · 生活型谱</p>
      <h2 id="spectrum-title" class="u-display spec-title">把整段下潜，收束成一组比例</h2>
      <p class="spec-lede">
        同样的五型，换一种读法——统计各**气候**下植物在五型中的占比，就得到一张
        <strong>生活型谱</strong>。它是气候的指纹：<em>高位芽</em>随热量减少而骤降，
        <em>一年生</em>在荒漠里爆发，<em>地面芽</em>在冷湿地带称王。
        每一条都是一支横放的剖面。
      </p>
    </header>

    <div class="spec-panel">
      <!-- 图例：可悬停 / 聚焦 / 点击，跨行高亮某一生活型 -->
      <ul class="legend" data-legend aria-label="生活型类目（悬停或点选以高亮）">
        {
          SPECTRUM_CLASSES.map((c) => (
            <li>
              <button class="legend-item" type="button" data-lf={c.lf}>
                <span class="sw" style={`--c:${c.color}`} />
                <span class="lz">{c.zh}</span>
                <span class="le u-label">{c.en}</span>
              </button>
            </li>
          ))
        }
      </ul>

      <!-- D3 增强容器（is-ready 后显示） -->
      <div class="spec-chart" data-spectrum aria-hidden="true"></div>

      <!-- SSR 静态兜底：无 JS 完整可用；is-ready 后视觉隐藏、保留给读屏 -->
      <div class="spec-fallback">
        {
          SPECTRUM_ROWS.map((row) => (
            <div class="fb-row">
              <p class="fb-label">
                <span class="fb-zh">{row.label}</span>
                <span class="fb-sub u-label">{row.sub}</span>
              </p>
              <div class="fb-bar" role="img" aria-label={fbLabel(row.label, row.values)}>
                {LIFEFORM_ORDER.map((lf) => (
                  <span
                    class="fb-seg"
                    style={`width:${row.values[lf]}%;--c:${SPECTRUM_COLOR[lf]}`}
                    data-lf={lf}
                  >
                    {row.values[lf] >= 10 && <span class="fb-pct">{row.values[lf]}</span>}
                  </span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <p class="spec-note u-label">
      数据为示意（据 Raunkiær 1934 及植物地理学经典整理，待按引文核实）；段色绿→褐＝冠层→种子，与下潜剖面同序。
    </p>
  </div>
</section>

<script>
  import '../scripts/spectrum.ts';
</script>

<style>
  .spectrum {
    position: relative;
    padding-block: clamp(var(--s7), 10vh, var(--s8));
    color: oklch(0.95 0.012 90); /* 终章在最深土场景之上，浅字 */
  }
  .wrap {
    max-width: var(--wrap-max);
    margin-inline: auto;
    padding-inline: var(--s5) var(--s6);
  }
  @media (max-width: 860px) {
    .wrap {
      padding-inline: var(--s4);
    }
  }

  .spec-head {
    max-width: 60ch;
    margin-bottom: var(--s6);
  }
  .kicker {
    color: oklch(0.8 0.03 95);
    margin-bottom: var(--s3);
  }
  .spec-title {
    font-size: var(--fs-h1);
    font-weight: 600;
    line-height: 1.1;
    margin-bottom: var(--s4);
  }
  .spec-lede {
    font-size: var(--fs-h3);
    line-height: 1.75;
    color: oklch(0.88 0.016 88);
  }
  .spec-lede strong {
    color: oklch(0.9 0.04 110);
    font-weight: 600;
  }
  .spec-lede em {
    font-style: normal;
    color: oklch(0.86 0.15 140); /* 仅文字强调，呼应芽绿 */
  }

  /* 暗玻璃面板：托住图谱，浅字可读 */
  .spec-panel {
    padding: clamp(var(--s4), 3vw, var(--s6));
    border-radius: var(--radius-lg);
    background: var(--glass-bg-dark);
    backdrop-filter: blur(var(--glass-blur)) saturate(1.3);
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(1.3);
    border: 1px solid var(--glass-border-dark);
    box-shadow: var(--glass-shadow), var(--glass-highlight-dark);
  }

  /* ---------- 图例 ---------- */
  .legend {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--s5);
    display: flex;
    flex-wrap: wrap;
    gap: var(--s2) var(--s4);
  }
  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: var(--s2);
    padding: 4px 8px;
    border: 0;
    background: transparent;
    color: inherit;
    border-radius: var(--radius-sm);
    cursor: pointer;
    font: inherit;
    transition: background var(--dur-1) var(--ease-out);
  }
  .legend-item:hover,
  .legend-item:focus-visible {
    background: oklch(1 0 0 / 0.08);
  }
  .sw {
    width: 14px;
    height: 14px;
    border-radius: 4px;
    background: var(--c);
    box-shadow: inset 0 0 0 1px oklch(1 0 0 / 0.25);
    flex: none;
  }
  .lz {
    font-family: var(--display);
    font-size: var(--fs-sm);
    font-weight: 540;
  }
  .le {
    color: oklch(0.72 0.02 85);
  }
  /* 当某类被激活：其它图例项压暗 */
  [data-spectrum-section].has-active .legend-item:not(.is-active) {
    opacity: 0.4;
  }

  /* ---------- D3 容器 / 兜底切换 ---------- */
  .spec-chart {
    display: none;
  }
  [data-spectrum-section].is-ready .spec-chart {
    display: block;
  }
  [data-spectrum-section].is-ready .spec-fallback {
    /* 切到 D3 视图后，兜底视觉隐藏但保留给读屏 */
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }

  /* ---------- SSR 静态堆叠条（无 JS 兜底，也是好看的基线） ---------- */
  .fb-row + .fb-row {
    margin-top: var(--s4);
  }
  .fb-label {
    display: flex;
    align-items: baseline;
    gap: var(--s3);
    margin-bottom: 6px;
  }
  .fb-zh {
    font-family: var(--display);
    font-size: var(--fs-sm);
    font-weight: 540;
  }
  .fb-sub {
    color: oklch(0.72 0.02 85);
  }
  .fb-bar {
    display: flex;
    height: 30px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    box-shadow: inset 0 0 0 1px oklch(1 0 0 / 0.12);
  }
  .fb-seg {
    position: relative;
    background: var(--c);
    box-shadow: inset -1px 0 0 oklch(0.2 0.02 60 / 0.25); /* 段间缝 */
    display: grid;
    place-items: center;
    min-width: 0;
  }
  .fb-pct {
    font-family: var(--mono);
    font-size: 0.6875rem;
    font-variant-numeric: tabular-nums;
    color: oklch(0.22 0.03 60);
  }
  /* 暗色段（隐芽/一年生）上的百分比用浅字 */
  .fb-seg[data-lf='cryptophyte'] .fb-pct,
  .fb-seg[data-lf='therophyte'] .fb-pct {
    color: oklch(0.95 0.012 90);
  }

  .spec-note {
    margin-top: var(--s5);
    max-width: 70ch;
    color: oklch(0.66 0.02 82);
    text-transform: none;
    letter-spacing: 0;
    line-height: 1.6;
  }
</style>

<style is:global>
  /* D3 生成的 SVG / tooltip 不受 scoped 样式约束，这里全局（限定在 .spectrum 内）。 */
  .spectrum .spec-chart svg {
    display: block;
    width: 100%;
    height: auto;
    overflow: visible;
    filter: drop-shadow(0 10px 24px oklch(0 0 0 / 0.3)); /* 高级投影 */
  }
  .spectrum .spec-axis-t {
    fill: oklch(0.6 0.02 82);
    font-family: var(--mono);
    font-size: 0.625rem;
  }
  .spectrum .spec-row-zh {
    fill: oklch(0.95 0.012 90);
    font-family: var(--display);
    font-size: 0.9rem;
    font-weight: 540;
  }
  .spectrum .spec-row-sub {
    fill: oklch(0.7 0.02 85);
    font-family: var(--sans);
    font-size: 0.72rem;
  }
  .spectrum .spec-pct {
    font-family: var(--mono);
    font-size: 0.7rem;
    font-variant-numeric: tabular-nums;
    transition: opacity 0.2s var(--ease-out);
  }
  .spectrum .spec-seg {
    transition: opacity 0.25s var(--ease-out), filter 0.25s var(--ease-out);
  }
  .spectrum .spec-seg:hover {
    filter: brightness(1.15) contrast(1.1); /* 鼠标悬停高级提亮 */
  }
  .spectrum .spec-tip {
    position: absolute;
    z-index: 5;
    pointer-events: none;
    transform: translate(-50%, calc(-100% - 12px));
    padding: 6px 10px;
    border-radius: 8px;
    background: oklch(0.16 0.02 60 / 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid oklch(1 0 0 / 0.14);
    color: oklch(0.95 0.012 90);
    font-size: 0.8rem;
    line-height: 1.45;
    white-space: nowrap;
    box-shadow: var(--shadow-2);
    transition: opacity 0.15s ease;
  }
  .spectrum .spec-tip .t-en {
    color: oklch(0.72 0.02 85);
    font-style: italic;
  }
  .spectrum .spec-tip .t-row {
    color: oklch(0.82 0.02 85);
  }
  .spectrum .spec-tip .t-pct {
    color: oklch(0.86 0.15 140);
  }
  @media (prefers-reduced-motion: reduce) {
    .spectrum .spec-seg,
    .spectrum .spec-pct {
      transition: none;
    }
  }
</style>
